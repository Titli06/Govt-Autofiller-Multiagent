# Copy to .env and fill in. NEVER commit the real .env.

# --- App ---
ENV=development

# --- Auth: access token (JWT) + DB-backed rotating refresh token ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
EMAIL_VERIFICATION_EXPIRE_HOURS=24

# --- Refresh cookie (httpOnly) ---
REFRESH_COOKIE_NAME=refresh_token
REFRESH_COOKIE_SECURE=false        # set true in prod (HTTPS)
REFRESH_COOKIE_SAMESITE=lax
REFRESH_COOKIE_PATH=/api/auth

# --- Field-level PII encryption (Phase 1, REQUIRED; 32-byte key, base64) ---
# Generate with: python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
PII_ENCRYPTION_KEY=change-me-base64-32-bytes

# --- PostgreSQL ---
DATABASE_URL=postgresql+psycopg://govfill:govfill@postgres:5432/govfill

# --- Redis / Celery ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- SMTP (Mailpit in dev; real provider creds in prod) ---
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=false
MAIL_FROM=no-reply@govfill.local

# --- URLs ---
FRONTEND_BASE_URL=http://localhost:5173   # used to build email verification links
# CORS_ORIGINS is empty in dev (same-origin via the Vite proxy). JSON list in prod, e.g.
# CORS_ORIGINS=["https://app.example.com"]

# --- Object storage (unused until Phase 1; S3-compatible: MinIO in dev, S3 in prod) ---
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=govfill-documents
S3_REGION=us-east-1

# --- Vision-LLM (Phase 1, REQUIRED for OCR extraction) ---
GEMINI_API_KEY=
VISION_MODEL=gemini-2.5-flash

# --- Confidence policy ---
CONFIDENCE_THRESHOLD=0.90

# --- Uploads (Phase 1) ---
MAX_UPLOAD_BYTES=10485760
MAX_UPLOAD_PAGES=10

# --- OCR / extraction worker (Phase 1) ---
OCR_MAX_RETRIES=3
OCR_RETRY_BACKOFF_SECONDS=5
OCR_CONFIDENCE_HIGH=0.90
OCR_CONFIDENCE_MEDIUM=0.70

# --- Schema inference for unseen forms (Phase 4) ---
# Google Document AI Form Parser — SERVICE-ACCOUNT auth (Application Default
# Credentials), NOT the Gemini API key above ("same GCP project" means shared
# billing only, not a drop-in credential). Create a Form Parser processor in that
# GCP project first (GCP Console -> Document AI -> Create Processor).
#
# Local Docker dev: run `gcloud auth application-default login` once on your host
# (see README.md's Document AI setup section), then set GCLOUD_ADC_HOST_PATH to
# wherever that command printed the credentials file. docker-compose.yml mounts it
# into the api/worker containers and sets GOOGLE_APPLICATION_CREDENTIALS itself, so
# leave that variable blank here — it's only needed here if running the worker
# directly on the host (no Docker) instead.
GOOGLE_APPLICATION_CREDENTIALS=
# Windows: %APPDATA%\gcloud\application_default_credentials.json (use forward
#   slashes, e.g. C:/Users/<you>/AppData/Roaming/gcloud/application_default_credentials.json)
# Mac/Linux: $HOME/.config/gcloud/application_default_credentials.json
GCLOUD_ADC_HOST_PATH=
DOCUMENTAI_PROJECT_ID=
DOCUMENTAI_LOCATION=us
DOCUMENTAI_PROCESSOR_ID=
# Below this detection confidence (or no value region found), a field is routed to
# the downloaded PDF's appended "Additional fields" page instead of a guessed position.
DOCUMENTAI_MIN_CONFIDENCE=0.5
# Discrete label-mapping tiers -> fixed confidence caps (never a raw LLM self-report;
# an inferred field can never present as "high" band).
MAP_CAP_EXACT=0.85
MAP_CAP_STRONG=0.70
MAP_CAP_WEAK=0.50

# --- Data purge (Phase 5) ---
# Pending/processing jobs older than this (seconds) no longer block DELETE /api/profile.
PURGE_STALE_JOB_SECONDS=900
